{% if cart.item_count == 0 %}
  <div class="v-404" style="text-align:center">
    <div class="err-num" style="font-size:80px;opacity:.2">○</div>
    <h2>Sepetiniz Boş</h2>
    <p>Henüz sepetinize ürün eklemediniz.</p>
    <a href="/collections/all" class="btn-gold">Alışverişe Başla</a>
  </div>
{% else %}
  <div class="v-sec" style="padding-top:140px">
    <h1 class="v-sec-h" style="margin-bottom:60px">Sepetim <em>({{ cart.item_count }} ürün)</em></h1>
    <div style="display:grid;grid-template-columns:1fr 360px;gap:60px;align-items:start">
      <div style="border-top:1px solid var(--border2)">
        {% for item in cart.items %}
          <div style="display:grid;grid-template-columns:90px 1fr auto;gap:20px;padding:28px 0;border-bottom:1px solid var(--border2);align-items:start">
            <div style="width:90px;height:110px;background:var(--black2);display:flex;align-items:center;justify-content:center;font-size:40px">
              {% if item.image %}<img src="{{ item.image | img_url: '180x' }}" style="width:90px;height:110px;object-fit:cover" alt="{{ item.title }}"/>{% else %}👕{% endif %}
            </div>
            <div>
              <div style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:300;margin-bottom:6px"><a href="{{ item.url }}" style="color:var(--white);text-decoration:none">{{ item.product.title }}</a></div>
              {% if item.variant.title != 'Default Title' %}
                <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--grey);margin-bottom:14px">{{ item.variant.title }}</div>
              {% endif %}
              <div style="display:flex;align-items:center;gap:12px">
                <form action="/cart" method="post">
                  <input type="hidden" name="updates[{{ item.key }}]" value="{{ item.quantity | minus: 1 }}"/>
                  <button type="submit" style="width:26px;height:26px;border:1px solid var(--border);color:var(--white);background:none;cursor:pointer;font-size:16px">−</button>
                </form>
                <span style="font-size:14px;min-width:20px;text-align:center">{{ item.quantity }}</span>
                <form action="/cart" method="post">
                  <input type="hidden" name="updates[{{ item.key }}]" value="{{ item.quantity | plus: 1 }}"/>
                  <button type="submit" style="width:26px;height:26px;border:1px solid var(--border);color:var(--white);background:none;cursor:pointer;font-size:16px">+</button>
                </form>
              </div>
            </div>
            <div style="text-align:right">
              <form action="/cart" method="post" style="margin-bottom:8px">
                <input type="hidden" name="updates[{{ item.key }}]" value="0"/>
                <button type="submit" style="background:none;border:none;color:var(--grey);cursor:pointer;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;font-family:'Montserrat',sans-serif">Kaldır</button>
              </form>
              <div style="font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--gold)">{{ item.final_line_price | money }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
      <div style="background:var(--black2);padding:40px;border:1px solid var(--border2);position:sticky;top:100px">
        <div style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:300;color:var(--white);margin-bottom:28px;letter-spacing:2px">Sipariş Özeti</div>
        <div style="display:flex;justify-content:space-between;margin-bottom:12px;font-size:12px;color:var(--grey)">
          <span>Ara Toplam</span><span>{{ cart.total_price | money }}</span>
        </div>
        <div style="display:flex;justify-content:space-between;margin-bottom:12px;font-size:12px;color:var(--grey)">
          <span>Kargo</span><span style="color:#4ade80">Ücretsiz</span>
        </div>
        <hr style="border:none;border-top:1px solid var(--border2);margin:20px 0"/>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px">
          <span style="font-size:11px;letter-spacing:2px;text-transform:uppercase">Toplam</span>
          <span style="font-family:'Cormorant Garamond',serif;font-size:28px;color:var(--gold)">{{ cart.total_price | money }}</span>
        </div>
        <a href="/checkout" class="cart-checkout-btn" style="display:block;text-align:center;padding:16px;text-decoration:none">Ödemeye Geç →</a>
        <a href="/collections/all" class="btn-outline" style="width:100%;margin-top:12px;justify-content:center;box-sizing:border-box">Alışverişe Devam Et</a>
      </div>
    </div>
  </div>
{% endif %}
